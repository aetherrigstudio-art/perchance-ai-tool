{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "basic-memory",
    "context7"
  ],
  "enableWorkflows": true,
  "workflowKeywordTriggerEnabled": true,
  "skillOverrides": {
    "agent-issue-tracker": "name-only",
    "agent-orchestrator-task": "name-only",
    "code-review-quality": "name-only",
    "code-security-audit": "name-only",
    "deep-research-agent": "name-only",
    "find-skills": "name-only",
    "plugin-settings": "name-only",
    "recap": "name-only",
    "roadmap-planning": "name-only",
    "self-reflecting-chain": "name-only",
    "session-start-hook": "name-only",
    "thought-based-reasoning": "name-only",
    "token-efficiency": "name-only",
    "track-management": "name-only",
    "ui-ux-pro-max": "name-only",
    "usability-testing": "name-only",
    "web-search": "name-only",
    "websearch-deep": "name-only"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(node *)",
      "Bash(cp *)",
      "Bash(md5sum *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(python3 *)",
      "Bash(bash *)",
      "Bash(npx *)",
      "Bash(npm *)",
      "Bash(uvx *)",
      "mcp__basic-memory__read_note",
      "mcp__basic-memory__search_notes",
      "mcp__basic-memory__recent_activity",
      "mcp__basic-memory__build_context",
      "mcp__basic-memory__write_note",
      "mcp__basic-memory__edit_note",
      "mcp__basic-memory__list_memory_projects",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "WebFetch(domain:context7.com)"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "*.pythonhosted.org",
        "github.com",
        "*.githubusercontent.com",
        "codeload.github.com",
        "skills.sh",
        "context7.com",
        "*.context7.com",
        "*.upstash.io",
        "playwright.azureedge.net",
        "cdn.playwright.dev"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\""
          },
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"basic-memory MCP (project perchar, ai-workspace/memory/) is the shared cross-session/cross-agent memory. At session start consult it (search_notes/recent_activity) for current state; record durable findings and decisions with write_note before ending a task.\"}}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-wizard.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-generator.py\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-router.sh\""
          }
        ]
      }
    ]
  }
}
